#!/usr/bin/env bash
# FlowAI — multi-agent terminal orchestrator (install once, use in any repo).
# shellcheck shell=bash

set -euo pipefail

# Invocation name: `flowai` vs `fai` (bin/fai is a symlink to this file — one script).
# Always derive from BASH_SOURCE; do not use FLOWAI_INVOKED_AS from the environment.
if [[ -n "${_FLOWAI_WRAPPER_INVOKED_AS:-}" ]]; then
  FLOWAI_INVOKED_AS="$_FLOWAI_WRAPPER_INVOKED_AS"
else
  FLOWAI_INVOKED_AS="${BASH_SOURCE[0]##*/}"
fi
export FLOWAI_INVOKED_AS

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(CDPATH="" cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
FLOWAI_HOME="$(CDPATH="" cd -P "$(dirname "$SOURCE")/.." >/dev/null 2>&1 && pwd)"
export FLOWAI_HOME
export FLOWAI_DIR="${FLOWAI_DIR:-$PWD/.flowai}"

# Avoid inherited BOLD/CYAN/RESET from the environment (can break ANSI if set to literal "\033...").
unset BOLD CYAN GREEN YELLOW RED RESET 2>/dev/null || true

# shellcheck source=src/core/log.sh
source "$FLOWAI_HOME/src/core/log.sh"
# shellcheck source=src/core/jq.sh
source "$FLOWAI_HOME/src/core/jq.sh"
flowai_prefer_jq_path
# shellcheck source=src/core/version.sh
source "$FLOWAI_HOME/src/core/version.sh"
# shellcheck source=src/core/phases.sh
source "$FLOWAI_HOME/src/core/phases.sh"

# Green line above main help (empty invocation, flowai help, -h, --help).
flowai_print_top_help_banner() {
  [[ "${FLOWAI_NO_HELP_BANNER:-0}" == "1" ]] && return 0
  local msg
  if [[ "${FLOWAI_INVOKED_AS:-flowai}" == "fai" ]]; then
    msg="fai — short for flowai; same commands everywhere."
  else
    msg="FlowAI — tip: run as fai … for the same CLI (faster to type)."
  fi
  if [[ -t 1 ]]; then
    printf '%b%s%b\n' "$GREEN" "$msg" "$RESET"
  else
    printf '%s\n' "$msg"
  fi
}

run_usage() {
  # Build phase list dynamically from canonical constant
  local phase_list="${CYAN}master${RESET}"
  local p
  for p in "${FLOWAI_PIPELINE_PHASES[@]}"; do
    phase_list+=", ${CYAN}${p}${RESET}"
  done
  # Show "implement" as an alias for "impl"
  phase_list+=", ${CYAN}implement${RESET}"
  cat <<EOF
${BOLD}flowai run — run a pipeline phase${RESET}

Usage:
  flowai run <phase> [args passed to the phase script]

Phases:
  ${phase_list}

Help:  flowai run -h | flowai run --help
EOF
}

usage() {
  cat <<EOF
${BOLD}FlowAI — Multi-agent terminal orchestrator${RESET}

Usage:
  flowai <command> [args...]    ${CYAN}# or: fai <command> …${RESET}

Commands:
  ${CYAN}init${RESET}        Initialize .flowai/ and bootstrap Spec Kit
  ${CYAN}start${RESET}       Start tmux session (self-heals dependencies)
  ${CYAN}kill${RESET}|${CYAN}stop${RESET}   Kill (or stop) the session for this repository
  ${CYAN}status${RESET}      Show session, config, Spec Kit, skills and MCP health
  ${CYAN}run${RESET}         Run a phase (e.g. ${CYAN}flowai run plan${RESET} or ${CYAN}fai run plan${RESET})
  ${CYAN}logs${RESET}        View logs for a backgrounded phase (${CYAN}flowai logs master${RESET})
  ${CYAN}graph${RESET}       Knowledge graph  (${CYAN}flowai graph build / update / query / lint${RESET})
  ${CYAN}skill${RESET}       Manage agent skills  (${CYAN}flowai skill add / apply / remove${RESET})
  ${CYAN}role${RESET}        Manage role prompts  (${CYAN}flowai role list / edit / set-prompt / reset${RESET})
  ${CYAN}mcp${RESET}         Manage MCP servers   (${CYAN}flowai mcp add / remove${RESET})
  ${CYAN}models${RESET}      List valid model ids per tool (from bundled catalog)
  ${CYAN}validate${RESET}    Check project config vs models-catalog.json (alias: ${CYAN}flowai config validate${RESET})
  ${CYAN}update${RESET}      Update FlowAI to latest version (${CYAN}flowai update --check${RESET} to preview)
  ${CYAN}version${RESET}     Print FlowAI version (for bug reports)

Help:  flowai help | flowai -h | flowai --help   ·   ${CYAN}flowai --version${RESET}
       ${CYAN}fai${RESET} is a shortcut for ${CYAN}flowai${RESET} (same binary features).

Examples:
  flowai init          # or: fai init
  flowai start
  flowai graph build
  flowai graph update
  flowai graph query "How does the skill resolution chain work?"
  flowai skill add obra/superpowers/systematic-debugging
  flowai skill add context7 obra/superpowers/systematic-debugging
  flowai mcp add github
  flowai models list
  flowai validate
  flowai update            # self-update to latest version
  flowai run plan
EOF
}

cmd="${1:-}"
shift || true

if [[ -z "$cmd" ]]; then
  flowai_print_top_help_banner
  usage
  exit 1
fi

case "$cmd" in
  init)
    bash "$FLOWAI_HOME/src/commands/init.sh" "$@"
    ;;
  start)
    bash "$FLOWAI_HOME/src/commands/start.sh" "$@"
    ;;
  kill|stop)
    bash "$FLOWAI_HOME/src/commands/kill.sh" "$@"
    ;;
  status)
    bash "$FLOWAI_HOME/src/commands/status.sh" "$@"
    ;;
  logs)
    bash "$FLOWAI_HOME/src/commands/logs.sh" "$@"
    ;;
  graph)
    bash "$FLOWAI_HOME/src/commands/graph.sh" "$@"
    ;;
  skill)
    bash "$FLOWAI_HOME/src/commands/skill.sh" "$@"
    ;;
  role)
    bash "$FLOWAI_HOME/src/commands/role.sh" "$@"
    ;;
  mcp)
    bash "$FLOWAI_HOME/src/commands/mcp.sh" "$@"
    ;;
  models)
    bash "$FLOWAI_HOME/src/commands/models.sh" "$@"
    ;;
  validate)
    bash "$FLOWAI_HOME/src/commands/config.sh" validate "$@"
    ;;
  config)
    bash "$FLOWAI_HOME/src/commands/config.sh" "$@"
    ;;
  update|self-update)
    bash "$FLOWAI_HOME/src/commands/update.sh" "$@"
    ;;
  run)
    phase="${1:-}"
    case "$phase" in
      -h|--help|help)
        run_usage
        exit 0
        ;;
    esac
    if [[ -z "$phase" ]]; then
      if [ -t 0 ] && [ "${FLOWAI_TESTING:-0}" != "1" ]; then
        log_info "No phase specified. Please choose one:"
        # Build choice list from canonical constant
        _choices=("master" "${FLOWAI_PIPELINE_PHASES[@]}" "implement")
        if command -v gum >/dev/null 2>&1; then
          phase="$(gum choose "${_choices[@]}")"
        else
          _phase_csv="$(IFS=', '; printf '%s' "${_choices[*]}")"
          read -r -p "Select phase (${_phase_csv}): " phase < /dev/tty || true
        fi
      fi
      if [[ -z "$phase" ]]; then
        log_error "Usage: flowai run <phase>   (e.g. master, plan, tasks, implement, review, spec)"
        exit 1
      fi
    fi
    shift || true
    case "$phase" in
      implement|impl) phase_script="implement" ;;
      *) phase_script="$phase" ;;
    esac
    if [[ ! -f "$FLOWAI_HOME/src/phases/${phase_script}.sh" ]]; then
      log_error "Unknown phase: $phase (no src/phases/${phase_script}.sh)"
      exit 1
    fi
    bash "$FLOWAI_HOME/src/phases/${phase_script}.sh" "$@"
    ;;
  -V|--version)
    flowai_version_print
    exit 0
    ;;
  version)
    flowai_version_print
    exit 0
    ;;
  -h|--help|help)
    flowai_print_top_help_banner
    usage
    exit 0
    ;;
  *)
    log_error "Unknown command: $cmd"
    usage
    exit 1
    ;;
esac
